+            output_dir=pyats_test_dirs.output_dir,
+            merged_data_filename="merged.yaml",
+            dry_run=True,
+        )
+
+        with patch.object(
+            orchestrator.test_discovery, "discover_pyats_tests"
+        ) as mock_discover:
+            mock_discover.return_value = ([api_test], [])
